{
  "name": "apicurio-registry-console-plugin",
  "version": "1.0.0",
  "private": true,
  "description": "OpenShift Console dynamic plugin for Apicurio Registry",
  "license": "Apache-2.0",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && NODE_ENV=production webpack && cp -r locales dist/locales",
    "dev": "webpack serve",
    "start": "npm run dev",
    "start-console": "./start-console.sh",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "i18n": "i18next 'src/**/*.{js,jsx,ts,tsx}' [-oc] -c i18next-parser.config.js"
  },
  "devDependencies": {
    "@openshift-console/dynamic-plugin-sdk": "4.20.0",
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.20.0",
    "@patternfly/react-core": "~5.4.14",
    "@patternfly/react-icons": "~5.4.2",
    "@patternfly/react-table": "~5.4.16",
    "ajv": "^8.17.0",
    "@swc/core": "^1.15.0",
    "@types/react": "~17.0.0",
    "@types/react-dom": "~17.0.0",
    "@types/react-router-dom": "~5.3.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.7.0",
    "i18next-parser": "^9.0.0",
    "react": "~17.0.2",
    "react-dom": "~17.0.2",
    "react-i18next": "~11.18.6",
    "react-router-dom": "~5.3.0",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.0",
    "webpack": "^5.107.0",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.5"
  },
  "consolePlugin": {
    "name": "apicurio-registry",
    "version": "1.0.0",
    "displayName": "Apicurio Registry",
    "description": "OpenShift Console plugin for managing Apicurio Registry instances",
    "exposedModules": {
      "RegistryListPage": "./components/RegistryListPage",
      "RegistryDetailPage": "./components/RegistryDetailPage"
    },
    "dependencies": {
      "@console/pluginAPI": "*"
    }
  }
}
